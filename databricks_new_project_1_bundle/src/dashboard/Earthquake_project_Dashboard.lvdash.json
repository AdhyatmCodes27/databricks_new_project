{
  "datasets": [
    {
      "name": "51c620ac",
      "displayName": "Earthquake_dashboard_dataset",
      "queryLines": [
        "SELECT *\n",
        "FROM project_development.silver.earthquake_data_final;"
      ]
    },
    {
      "name": "f8cc8c3c",
      "displayName": "Earthquake_type",
      "queryLines": [
        "SELECT count(*) AS total_magnitude_bucket, magnitude_bucket\n",
        "FROM \n",
        "    (\n",
        "        SELECT CASE\n",
        "            WHEN mag < 2 THEN 'Micro (<2)'\n",
        "            WHEN mag BETWEEN 2 AND 3 THEN 'Minor (2-3)'\n",
        "            WHEN mag BETWEEN 3 AND 4 THEN 'Light (3-4)'\n",
        "            ELSE 'Moderate+ (4+)'\n",
        "            END AS magnitude_bucket\n",
        "        FROM earthquake_data_final\n",
        "    )\n",
        "GROUP BY magnitude_bucket;"
      ],
      "catalog": "project_development",
      "schema": "silver"
    },
    {
      "name": "d43777ad",
      "displayName": "Earthquake_place",
      "queryLines": [
        "SELECT count(*) AS event_count, \n",
        "    -- CASE \n",
        "    -- WHEN size(split(place, ', ')) = 1 THEN split(place, ', ')[0]\n",
        "    -- ELSE split(place, ', ')[1]\n",
        "    -- END AS place_of_earthquake\n",
        "    get(split(place, ', '), 1) AS place_of_earthquake\n",
        "FROM (\n",
        "    SELECT time, title, mag, longitude, place, latitude \n",
        "    FROM silver.earthquake_data_final\n",
        "     )\n",
        "GROUP BY place_of_earthquake;\n"
      ],
      "catalog": "project_development",
      "schema": "silver"
    }
  ],
